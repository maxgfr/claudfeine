{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogTitle": "# Changelog\n\nAll notable changes to claudfeine are documented here. This file is generated by [semantic-release](https://github.com/semantic-release/semantic-release) from the [Conventional Commits](https://www.conventionalcommits.org/) on `main`."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bash .version-hook.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["claudfeine", "windows/_feine.ps1", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
